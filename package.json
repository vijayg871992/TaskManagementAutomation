{
  "name": "jarvis-agent",
  "version": "1.0.0",
  "description": "Jarvis task agent for JAB Enterprises — natural-language task assignment, PWA dashboard, daily digest.",
  "type": "commonjs",
  "main": "src/web/app.js",
  "scripts": {
    "start": "node src/server.js",
    "migrate": "knex migrate:latest",
