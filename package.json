    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "knex": "^3.1.0",
    "luxon": "^3.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
