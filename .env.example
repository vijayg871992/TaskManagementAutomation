# ---- App ----
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
APP_TZ=America/New_York
# Public base URL (used in emails / links). No trailing slash.
APP_BASE_URL=http://localhost:3000

# ---- Database ----
# Demo (VPS): better-sqlite3   |   Azure: pg
DB_CLIENT=better-sqlite3
# Used only when DB_CLIENT=better-sqlite3
SQLITE_FILE=./data/jarvis.sqlite
# Used only when DB_CLIENT=pg
DATABASE_URL=postgres://user:pass@host:5432/jarvis

# ---- NLP (Gemini free tier only — NO billing / NO Vertex) ----
# mock = deterministic offline parser (used by the test harness)
# gemini = Google AI Studio free-tier API
NLP_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- SMS OTP ----
# console = log the code to stdout (demo)   |   aloware = send via Aloware API
SMS_PROVIDER=console
ALOWARE_API_BASE=https://app.aloware.io
ALOWARE_API_TOKEN=
# Provide EITHER a "from" line phone number OR a line_id (from your Aloware account):
ALOWARE_FROM=
ALOWARE_LINE_ID=
# Optional: -1 = send as company, 0 = contact owner, or a specific Aloware user id
ALOWARE_USER_ID=-1

# ---- Email digest ----
# file = write rendered email to ./data/outbox (demo)   |   smtp = real send
EMAIL_PROVIDER=file
EMAIL_FROM="JAB Jarvis <noreply@example.com>"
# SMTP (e.g. Office 365 / Outlook): smtp.office365.com : 587, STARTTLS
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ---- Web Push (free, VAPID) — generate with: npx web-push generate-vapid-keys ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
